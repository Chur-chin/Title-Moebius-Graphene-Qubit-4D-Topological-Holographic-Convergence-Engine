import numpy as np

def apply_uv_moebius_logic(wave_array, uv_intensity):
    """
    출력부 근처 UV 조사에 따른 Möbius 위상 반전 적용
    uv_intensity가 특정 임계값을 넘으면 위상이 pi만큼 flip됨
    """
    L = len(wave_array)
    output_region = int(L * 0.8)  # 출력부 근처 (80% 지점 이후)
    
    # UV 강도에 따른 위상 천이 계산 (간단한 선형 모델)
    phase_shift = np.pi if uv_intensity > 0.5 else 0
    
    modified_wave = np.copy(wave_array).astype(complex)
    # 출력부 영역에 위상 반전 적용 (Möbius 효과 모사)
    modified_wave[output_region:] *= np.exp(1j * phase_shift)
    
    return modified_wave
